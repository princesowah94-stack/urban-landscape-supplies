# ─── Square (get from Square Developer Dashboard → your app) ────────────────
# Production Access Token (starts with EAAAl...)
SQUARE_ACCESS_TOKEN=

# Location ID (Square Dashboard → Locations)
SQUARE_LOCATION_ID=

# Set to 'production' for live payments, anything else uses Sandbox
SQUARE_ENVIRONMENT=production

# Webhook Signature Key (Square Dashboard → Webhooks → your endpoint → Signature Key)
# Register the webhook URL as: https://urbanlandscapesupplies.com.au/api/square-webhook
# Subscribe to event: payment.updated
SQUARE_WEBHOOK_SIGNATURE_KEY=

# Optional: override the webhook URL if your domain differs
# SQUARE_WEBHOOK_URL=https://urbanlandscapesupplies.com.au/api/square-webhook

# ─── Supabase ───────────────────────────────────────────────────────────────
# Project Settings → API → Project URL
SUPABASE_URL=

# Project Settings → API → service_role key (not the anon key)
SUPABASE_SERVICE_ROLE_KEY=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# resend.com → API Keys
RESEND_API_KEY=

# From address (must be a verified domain in Resend)
EMAIL_FROM=orders@urbanlandscapesupplies.com.au

# Staff email — receives a copy of every new order
EMAIL_TO_STAFF=orders@urbanlandscapesupplies.com.au

# Supplier email(s) — comma-separated if multiple
SUPPLIER_NOTIFICATION_EMAIL=

# ─── Site ────────────────────────────────────────────────────────────────────
SITE_URL=https://urbanlandscapesupplies.com.au
