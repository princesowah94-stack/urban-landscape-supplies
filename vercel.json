{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/delivery/:suburb", "destination": "/delivery-suburb.html?suburb=:suburb" }
  ],
  "redirects": [
    { "source": "/bulk-materials", "destination": "/products", "permanent": true },
    { "source": "/bulk-materials.html", "destination": "/products", "permanent": true },
    { "source": "/:path*", "has": [{ "type": "host", "value": "www.urbanlandscapesupplies.com.au" }], "destination": "https://urbanlandscapesupplies.com.au/:path*", "permanent": true }
  ],
  "crons": [
    { "path": "/api/cron/cleanup-orphans", "schedule": "0 17 * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://esm.sh; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://*.supabase.co https://www.google-analytics.com https://api.squareup.com https://connect.squareup.com https://pci-connect.squareupsandbox.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self';" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/admin",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/admin.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/data/(.*\\.json)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/(.*\\.(?:css|js))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*\\.(?:jpg|png|svg|webp|ico))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800" }
      ]
    }
  ]
}
